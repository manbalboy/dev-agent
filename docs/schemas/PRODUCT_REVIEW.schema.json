{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenthub.local/schemas/product_review.schema.json",
  "title": "ProductReview",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "job_id",
    "scores",
    "score_reasons",
    "findings",
    "improvement_candidates",
    "priority_summary",
    "recommended_next_tasks",
    "quality_signals",
    "validation",
    "quality_gate"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "job_id": { "type": "string" },
    "review_basis": {
      "type": "object",
      "properties": {
        "spec": { "type": "string" },
        "plan": { "type": "string" },
        "review": { "type": "string" }
      },
      "additionalProperties": true
    },
    "scores": {
      "type": "object",
      "required": [
        "code_quality",
        "architecture_structure",
        "maintainability",
        "usability",
        "ux_clarity",
        "test_coverage",
        "error_state_handling",
        "empty_state_handling",
        "loading_state_handling",
        "overall"
      ],
      "properties": {
        "code_quality": { "type": "number", "minimum": 0, "maximum": 5 },
        "architecture_structure": { "type": "number", "minimum": 0, "maximum": 5 },
        "maintainability": { "type": "number", "minimum": 0, "maximum": 5 },
        "usability": { "type": "number", "minimum": 0, "maximum": 5 },
        "ux_clarity": { "type": "number", "minimum": 0, "maximum": 5 },
        "test_coverage": { "type": "number", "minimum": 0, "maximum": 5 },
        "error_state_handling": { "type": "number", "minimum": 0, "maximum": 5 },
        "empty_state_handling": { "type": "number", "minimum": 0, "maximum": 5 },
        "loading_state_handling": { "type": "number", "minimum": 0, "maximum": 5 },
        "overall": { "type": "number", "minimum": 0, "maximum": 5 }
      },
      "additionalProperties": false
    },
    "score_reasons": {
      "type": "object",
      "required": [
        "code_quality",
        "architecture_structure",
        "maintainability",
        "usability",
        "ux_clarity",
        "test_coverage",
        "error_state_handling",
        "empty_state_handling",
        "loading_state_handling"
      ],
      "properties": {
        "code_quality": { "type": "string" },
        "architecture_structure": { "type": "string" },
        "maintainability": { "type": "string" },
        "usability": { "type": "string" },
        "ux_clarity": { "type": "string" },
        "test_coverage": { "type": "string" },
        "error_state_handling": { "type": "string" },
        "empty_state_handling": { "type": "string" },
        "loading_state_handling": { "type": "string" }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "summary"],
        "properties": {
          "category": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "improvement_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "priority", "reason"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "title": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "priority_summary": {
      "type": "object",
      "required": ["P0", "P1", "P2", "P3"],
      "properties": {
        "P0": { "type": "integer", "minimum": 0 },
        "P1": { "type": "integer", "minimum": 0 },
        "P2": { "type": "integer", "minimum": 0 },
        "P3": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "recommended_next_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "priority", "reason", "action"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "reason": { "type": "string" },
          "action": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "quality_signals": {
      "type": "object",
      "required": [
        "todo_items_count",
        "critical_issue_keywords_detected",
        "test_report_count",
        "test_failures_count",
        "test_passes_count",
        "has_product_brief",
        "has_user_flows",
        "has_mvp_scope",
        "has_architecture_plan",
        "has_ux_review"
      ],
      "properties": {
        "todo_items_count": { "type": "integer", "minimum": 0 },
        "critical_issue_keywords_detected": { "type": "boolean" },
        "test_report_count": { "type": "integer", "minimum": 0 },
        "test_failures_count": { "type": "integer", "minimum": 0 },
        "test_passes_count": { "type": "integer", "minimum": 0 },
        "has_product_brief": { "type": "boolean" },
        "has_user_flows": { "type": "boolean" },
        "has_mvp_scope": { "type": "boolean" },
        "has_architecture_plan": { "type": "boolean" },
        "has_ux_review": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["passed", "errors", "checked_at"],
      "properties": {
        "passed": { "type": "boolean" },
        "errors": { "type": "array", "items": { "type": "string" } },
        "checked_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "quality_gate": {
      "type": "object",
      "required": ["passed", "reason"],
      "properties": {
        "passed": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
