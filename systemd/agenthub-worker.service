[Unit]
Description=AgentHub orchestration worker
After=network.target

[Service]
Type=simple
User=docker
WorkingDirectory=/home/docker/agentHub
EnvironmentFile=/home/docker/agentHub/.env
ExecStart=/home/docker/agentHub/.venv/bin/python -m app.worker_main
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
